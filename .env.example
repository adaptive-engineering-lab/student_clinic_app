# --- Frontend (exposed to the browser bundle — must be prefixed VITE_) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Server-side only (Supabase Edge Functions — never bundled to the client) ---
# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are auto-injected into
# every Edge Function by the platform (locally and in production) — the SUPABASE_
# prefix is reserved, so they can't be set here or via `supabase secrets set`. Only
# genuinely custom secrets go below.
SUPABASE_JWKS_URL=
RESEND_API_KEY=
